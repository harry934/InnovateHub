rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Check if user has a specific role
    function hasRole(role) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Helper: Is the user the owner of the document
    function isOwner(userIdField) {
      return request.auth != null && request.resource.data[userIdField] == request.auth.uid;
    }
    
    function isDocOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users: Profiles and Metadata
    match /users/{userId} {
      allow read: if request.auth != null; // Mentors/Innovators need to see each other
      allow write: if isDocOwner(userId) || hasRole('admin');
    }

    // Projects: The core innovation data
    match /projects/{projectId} {
      allow read: if hasRole('admin') || 
                   resource.data.innovatorId == request.auth.uid || 
                   resource.data.mentorId == request.auth.uid ||
                   resource.data.visibility == 'public';
      allow create: if hasRole('innovator');
      allow update: if hasRole('admin') || 
                     resource.data.innovatorId == request.auth.uid ||
                     resource.data.mentorId == request.auth.uid;
      allow delete: if hasRole('admin') || resource.data.innovatorId == request.auth.uid;
    }

    // Milestones: Sub-goals of projects
    match /milestones/{milestoneId} {
      allow read: if request.auth != null; 
      allow write: if hasRole('admin') || hasRole('mentor') || hasRole('innovator');
      // More specific checks will be handled in the logic layer for now, 
      // but rules ensure basic role check.
    }

    // Mentorship Requests
    match /mentorshipRequests/{requestId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == resource.data.innovatorId || 
         request.auth.uid == resource.data.mentorId || 
         hasRole('admin'));
      allow create: if hasRole('innovator');
    }

    // Reports: Progress updates
    match /reports/{reportId} {
      allow read: if request.auth != null && 
        (hasRole('admin') || 
         request.auth.uid == resource.data.mentorId || 
         request.auth.uid == resource.data.innovatorId);
      allow create: if hasRole('innovator');
    }

    // Events: Admin managed
    match /events/{eventId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // Notifications: User specific
    match /notifications/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null; // System generated
    }
    
    // Ratings
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if hasRole('innovator');
      allow update, delete: if hasRole('admin');
    }
    
    // Meetings
    match /meetings/{meetingId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == resource.data.mentorId || 
         request.auth.uid == resource.data.innovatorId || 
         hasRole('admin'));
    }
  }
}
