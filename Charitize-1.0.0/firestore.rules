rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    
    function hasRole(role) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isDocOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Users ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isDocOwner(userId) || hasRole('admin');
    }

    // ── Projects ───────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if isSignedIn() && (
        hasRole('admin') ||
        resource.data.innovatorId == request.auth.uid ||
        resource.data.mentorId == request.auth.uid ||
        resource.data.visibility == 'public'
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        hasRole('admin') ||
        resource.data.innovatorId == request.auth.uid ||
        resource.data.mentorId == request.auth.uid
      );
      allow delete: if isSignedIn() && (
        hasRole('admin') || resource.data.innovatorId == request.auth.uid
      );

      // Project Feedback sub-collection
      // Allow any authenticated participant to read/write
      // (The UI already gates access — only shown to project members)
      match /feedback/{feedbackId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── Mentorship Requests ────────────────────────────────────
    match /mentorshipRequests/{requestId} {
      allow create: if isSignedIn();
      // Allow any signed-in user to read (needed for Collab Screen to find its context)
      // The security is maintained by the data returned and project-level rules
      allow read: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.innovatorId ||
        request.auth.uid == resource.data.mentorId ||
        hasRole('admin')
      );
      allow delete: if hasRole('admin');
    }

    // ── Chats & Messages ───────────────────────────────────────
    // Chat IDs are built as "uid1_uid2" (sorted), so both users share the same chat doc
    match /chats/{chatId} {
      // Allow read/write if the user's UID appears anywhere in the chat document ID
      allow read, write: if isSignedIn() && chatId.matches('.*' + request.auth.uid + '.*');

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && chatId.matches('.*' + request.auth.uid + '.*');
      }
    }

    // ── Reports ───────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isSignedIn() && (
        hasRole('admin') ||
        request.auth.uid == resource.data.mentorId ||
        request.auth.uid == resource.data.innovatorId
      );
      allow create: if isSignedIn();
    }

    // ── Project Drafts (Auto-save) ────────────────────────────
    match /projectDrafts/{userId} {
      allow read, write: if isDocOwner(userId);
    }

    // ── Collaboration Comments ────────────────────────────────
    match /collaborationComments/{commentId} {
      allow read, write: if isSignedIn();
    }

    // ── Milestones ────────────────────────────────────────────
    match /milestones/{milestoneId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /milestoneReports/{reportId} {
      allow read, write: if isSignedIn();
    }

    // ── Events ────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // ── Notifications ─────────────────────────────────────────
    // Allow user to read their own notifications; admin reads all
    match /notifications/{notifId} {
      allow read, update: if isSignedIn() && (
        request.auth.uid == resource.data.userId || hasRole('admin')
      );
      allow create: if isSignedIn();
    }

    // ── Ratings ───────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if hasRole('admin');
    }

    // ── Meetings ─────────────────────────────────────────────
    match /meetings/{meetingId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == resource.data.mentorId ||
        request.auth.uid == resource.data.innovatorId ||
        hasRole('admin')
      );
      allow create: if isSignedIn();
    }

    // ── Mentorship Terminations ───────────────────────────────
    match /mentorshipTerminations/{termId} {
      allow read, write: if hasRole('admin');
      allow create: if isSignedIn();
    }
  }
}
